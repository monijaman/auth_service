# Copy to .env and fill in values before running
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars

# Optional overrides (defaults match docker-compose.yml)
# DATABASE_URL=postgres://auth_user:auth_pass@localhost:5432/auth_db?sslmode=disable
# REDIS_ADDR=localhost:6379
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# PORT=8080

# Email (SMTP)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
